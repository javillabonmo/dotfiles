{
  "$schema": "https://opencode.ai/config.json",
  "theme": "catppuccin-macchiato",
  "mcp": {
    "filesystem": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/home/{env:USER}"
      ]
    },
    "postgres": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://{env:POSTGRES_USER}:{env:POSTGRES_PASSWORD}@localhost:5432/{env:POSTGRES_DB}"
      ],
      "enabled": false
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["bunx", "-y", "chrome-devtools-mcp@latest"]
    },
    "obsidian": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "@bitbonsai/mcpvault@latest",
        "{env:OBSIDIAN_VAULT}"
      ],
      "enabled": true
    },
    "playwright": {
      "command": "bunx",
      "args": ["@playwright/mcp@latest"]
    }
  }
}
